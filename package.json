{
  "name": "pi-venice",
  "version": "0.1.2",
  "description": "Pi Coding Agent extension for using Venice.ai as provider",
  "license": "Apache-2.0",
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "homepage": "https://github.com/tunnckoCore/pi-venice",
  "repository": {
    "type": "git",
    "url": "https://github.com/tunnckoCore/pi-venice.git"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "bunx tsgo-dev -p ./tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "pi-venice",
    "venice",
    "venice.ai",
    "llm",
    "ai",
    "provider"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
